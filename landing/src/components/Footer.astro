---
import { useTranslations, localizedPath, type Lang } from '../i18n/ui'
import { SITE, PRICING } from '../data/site'

const { lang } = Astro.props as { lang: Lang }
const t = useTranslations(lang)
const year = new Date().getFullYear()
const home = localizedPath(lang, '/')
---

<footer>
  <div class="wrap">
    <div class="foot-grid">
      <div>
        <div class="flogo">
          <img src="/logo-mark-white.png" alt={SITE.name} height="30" />
          <span class="fword">QR<span>Log</span></span>
        </div>
        <p>{t('foot.tag')}</p>
      </div>
      <div class="fcol">
        <h4>{t('foot.product')}</h4>
        <a href={`${home}#features`}>{t('nav.features')}</a>
        <a href={`${home}#how`}>{t('nav.how')}</a>
        {PRICING.enabled && <a href={localizedPath(lang, '/qiymet/')}>{t('nav.pricing')}</a>}
        <a href={`${home}#faq`}>{t('nav.faq')}</a>
      </div>
      <div class="fcol">
        <h4>{t('foot.company')}</h4>
        <a href={localizedPath(lang, '/haqqimizda/')}>{t('foot.about')}</a>
        <!-- The blog is written in Azerbaijani only, so every language points at the AZ index. -->
        <a href="/bloq/">{t('foot.blog')}</a>
        <a href={localizedPath(lang, '/elaqe/')}>{t('nav.contact')}</a>
      </div>
      <div class="fcol">
        <h4>{t('foot.contact')}</h4>
        <a href={`mailto:${SITE.email}`}>{SITE.email}</a>
        {SITE.phone && <a href={`tel:${SITE.phone.replace(/[^+\d]/g, '')}`}>{SITE.phone}</a>}
      </div>
    </div>
    <div class="foot-bot">
      <span>© {year} {SITE.name}. {t('foot.rights')}</span>
      <span>{SITE.address}</span>
    </div>
  </div>
</footer>
