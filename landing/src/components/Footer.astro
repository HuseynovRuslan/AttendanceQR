---
import { SITE } from '../data/site'

const year = 2026
const links = [
  { label: 'Xüsusiyyətlər', href: '/#xususiyyetler' },
  { label: 'Necə işləyir', href: '/#nece-isleyir' },
  { label: 'Qiymət', href: '/#qiymet' },
  { label: 'Haqqımızda', href: '/haqqimizda' },
  { label: 'Əlaqə', href: '/elaqe' },
]
---

<footer class="border-t border-hair bg-surface">
  <div class="mx-auto max-w-6xl px-4 py-14 sm:px-6">
    <div class="grid gap-8 sm:grid-cols-2 md:grid-cols-4">
      <div class="md:col-span-2">
        <a href="/" class="flex items-center gap-2.5" aria-label="QRLog">
          <svg class="h-7 w-7 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><path d="M14 14h3v3M21 14v3M14 21h7M21 17v4"/>
          </svg>
          <span class="display text-lg font-extrabold text-body">QRLog</span>
        </a>
        <p class="mt-3 max-w-sm text-sm leading-relaxed text-dim">
          QR əsaslı işçi davamiyyəti sistemi — telefonla giriş-çıxış, GPS məkan yoxlaması və cihaz
          bağlaması ilə saxta girişə qarşı qorunma.
        </p>
      </div>

      <nav aria-label="Alt naviqasiya">
        <h2 class="text-sm font-bold text-body">Səhifələr</h2>
        <ul class="mt-3 space-y-2">
          {links.map((l) => (
            <li><a href={l.href} class="text-sm text-dim transition hover:text-accent">{l.label}</a></li>
          ))}
        </ul>
      </nav>

      <div>
        <h2 class="text-sm font-bold text-body">Əlaqə</h2>
        <ul class="mt-3 space-y-2 text-sm text-dim">
          <li><a href={`mailto:${SITE.email}`} class="transition hover:text-accent">{SITE.email}</a></li>
          <li>{SITE.address}</li>
          <li><a href={SITE.appUrl} target="_blank" rel="noopener noreferrer" class="font-semibold text-accent">İşçi girişi →</a></li>
        </ul>
      </div>
    </div>

    <div class="mt-10 border-t border-hair pt-6 text-center text-xs text-dim">
      © {year} {SITE.name} · {SITE.domain}
    </div>
  </div>
</footer>
