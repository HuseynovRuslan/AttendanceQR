---
interface Props {
  href: string
  variant?: 'primary' | 'ghost' | 'white'
  class?: string
  external?: boolean
}
const { href, variant = 'primary', class: cls = '', external = false } = Astro.props

const base =
  'inline-flex items-center justify-center gap-2 rounded-xl px-6 py-3 text-base font-semibold transition focus:outline-none focus-visible:ring-4 focus-visible:ring-primary/30'
const styles = {
  primary: 'bg-primary text-white hover:bg-primary-dark shadow-sm',
  ghost: 'text-ink ring-1 ring-ink/15 hover:bg-soft',
  white: 'bg-white text-primary hover:bg-soft shadow-sm',
}
const rel = external ? 'noopener noreferrer' : undefined
const target = external ? '_blank' : undefined
---

<a href={href} class={`${base} ${styles[variant]} ${cls}`} rel={rel} target={target}>
  <slot />
</a>
