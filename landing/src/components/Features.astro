---
import Icon from './Icon.astro'
import { FEATURES } from '../data/site'
---

<section id="xususiyyetler" class="bg-white py-16 sm:py-24">
  <div class="mx-auto max-w-6xl px-4 sm:px-6">
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="text-3xl font-bold text-ink sm:text-4xl">Niyə QRLog?</h2>
      <p class="mt-4 text-lg text-muted">
        İşçi giriş-çıxış qeydiyyatını sadələşdirən, saxtakarlığa qarşı qoruyan xüsusiyyətlər.
      </p>
    </div>

    <div class="mt-14 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {FEATURES.map((f) => (
        <article class="rounded-2xl bg-soft p-7 ring-1 ring-ink/5 transition hover:shadow-md">
          <div class="grid h-12 w-12 place-items-center rounded-xl bg-primary/10 text-primary">
            <Icon name={f.icon} class="h-6 w-6" />
          </div>
          <h3 class="mt-5 text-lg font-bold text-ink">{f.title}</h3>
          <p class="mt-2 text-sm leading-relaxed text-muted">{f.text}</p>
        </article>
      ))}
    </div>
  </div>
</section>
