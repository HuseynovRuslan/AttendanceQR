---
// Simple heading block for the stub pages, so they share one look.
interface Props {
  title: string
  subtitle?: string
}
const { title, subtitle } = Astro.props
---

<section class="bg-soft py-16 sm:py-20">
  <div class="mx-auto max-w-3xl px-4 text-center sm:px-6">
    <h1 class="text-3xl font-bold text-ink sm:text-4xl">{title}</h1>
    {subtitle && <p class="mx-auto mt-4 max-w-xl text-lg text-muted">{subtitle}</p>}
  </div>
</section>
