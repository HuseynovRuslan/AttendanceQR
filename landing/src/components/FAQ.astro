---
import { useTranslations, type Lang } from '../i18n/ui'

const { lang } = Astro.props as { lang: Lang }
const t = useTranslations(lang)

// Keep this list and the FAQPage JSON-LD in BaseLayout.astro on the same range of keys.
const qs = [1, 2, 3, 4, 5, 6]
const plus = '<path d="M12 5v14M5 12h14"/>'
---

<section id="faq">
  <div class="wrap">
    <div class="sec-head rv">
      <span class="eyebrow">{t('faq.eyebrow')}</span>
      <h2>{t('faq.title')}</h2>
      <p>{t('faq.sub')}</p>
    </div>
    <div class="faq-list">
      {qs.map((i, idx) => (
        <div class={`faq-item rv d${(idx % 5) + 1}`}>
          <button class="faq-q" aria-expanded="false">
            <span>{t(`faq.q${i}` as any)}</span>
            <span class="ico"><svg viewBox="0 0 24 24" set:html={plus} /></span>
          </button>
          <div class="faq-a"><p>{t(`faq.a${i}` as any)}</p></div>
        </div>
      ))}
    </div>
  </div>
</section>
