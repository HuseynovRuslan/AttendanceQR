---
import { useTranslations, localizedPath, type Lang } from '../i18n/ui'
import { PRICING } from '../data/site'

interface Props {
  lang: Lang
  /** The /qiymet/ page renders the same block with its own <h1>, so it hides the section heading. */
  bare?: boolean
}
const { lang, bare = false } = Astro.props
const t = useTranslations(lang)
const contact = localizedPath(lang, '/elaqe/')
const check = '<path d="m5 13 4 4L19 7"/>'

// Amounts come from PRICING in src/data/site.ts. While showPlans is false the plan table is not
// rendered at all — the page keeps its heading and answers with "we quote per organisation".
// Hiding only the nav link would have left these pages live and indexable with invented numbers on
// them, which is the failure this guard exists to prevent.
const plans = PRICING.plans.map((p) => ({
  amount: p.amount as string | null,
  featured: p.featured as boolean,
  name: t(`price.p${p.id}n` as any),
  desc: t(`price.p${p.id}d` as any),
  fallbackAmount: t(`price.p${p.id}a` as any),
  cta: t(`price.p${p.id}c` as any),
  features: Array.from({ length: p.featureCount }, (_, n) => t(`price.p${p.id}f${n + 1}` as any)),
}))
---

<section class="price" id="pricing">
  <div class="wrap">
    {!bare && (
      <div class="sec-head rv">
        <span class="eyebrow">{t('price.eyebrow')}</span>
        <h2>{t('price.title')}</h2>
        <p>{t('price.sub')}</p>
      </div>
    )}
    {!PRICING.showPlans && (
      <div class="quote-card rv">
        <h3>{t('price.quoteTitle')}</h3>
        <p>{t('price.quoteText')}</p>
        <a href={contact} class="btn btn-primary">{t('price.quoteBtn')}</a>
      </div>
    )}

    {PRICING.showPlans && (
    <div class="plans">
      {plans.map((p, i) => (
        <div class={`plan rv d${i + 1}${p.featured ? ' feat-plan' : ''}`}>
          {p.featured && <span class="tag">{t('price.popular')}</span>}
          <h3>{p.name}</h3>
          <div class="pdesc">{p.desc}</div>
          <div class="amt">
            {p.amount ? <>{p.amount}<small>{t('price.mo')}</small></> : p.fallbackAmount}
          </div>
          <ul>
            {p.features.map((f) => (
              <li><svg viewBox="0 0 24 24" set:html={check} /><span>{f}</span></li>
            ))}
          </ul>
          <a href={contact} class={`btn ${p.featured ? 'btn-primary' : 'btn-ghost'}`}>{p.cta}</a>
        </div>
      ))}
    </div>
    )}
    {PRICING.showPlans && <p class="price-note rv">{t('price.note')}</p>}
  </div>
</section>
