---
// Prices are intentionally not shown — packages are quoted per business (no self-serve signup yet).
// Every CTA leads to contact. Update the plan feature lists as the offering firms up.
const plans = [
  {
    name: 'Başlanğıc',
    tagline: 'Kiçik komanda, bir filial',
    features: ['1 filial', 'Limitsiz işçi', 'QR giriş-çıxış', 'Canlı panel', 'Excel hesabat'],
    featured: false,
  },
  {
    name: 'Biznes',
    tagline: 'Bir neçə filial və menecerlər',
    features: ['Çoxfilial idarəetmə', 'Menecer rolları', 'GPS + cihaz bağlaması', 'Toplu işçi əlavəsi', 'Prioritet dəstək'],
    featured: true,
  },
  {
    name: 'Korporativ',
    tagline: 'Böyük heyət, xüsusi tələblər',
    features: ['Fərdi qurulum', 'İnteqrasiya imkanları', 'Xüsusi hesabatlar', 'Təlim və müşayiət', 'SLA dəstək'],
    featured: false,
  },
]
---

<section id="qiymet" class="bg-surface py-18 sm:py-24">
  <div class="mx-auto max-w-6xl px-4 sm:px-6">
    <div class="mx-auto max-w-2xl text-center">
      <span class="eyebrow centered">Qiymət</span>
      <h2 class="display mt-4 text-3xl font-extrabold text-body sm:text-4xl">Biznesinizə uyğun paket</h2>
      <p class="mt-4 text-lg text-dim">
        Qiymət işçi sayı və filial sayına görə fərqlənir. Sizə uyğun paketi birlikdə seçək —
        əlaqə saxlayın, pulsuz demo göstərək.
      </p>
    </div>

    <div class="mt-12 grid gap-5 lg:grid-cols-3">
      {plans.map((p) => (
        <div class={`card relative flex flex-col p-7 ${p.featured ? 'ring-2' : ''}`} style={p.featured ? 'border-color:var(--accent); box-shadow:var(--shadow-lg)' : ''}>
          {p.featured && (
            <span class="absolute -top-3 left-7 rounded-full px-3 py-1 text-xs font-bold" style="background:var(--accent); color:var(--accent-ink)">Ən populyar</span>
          )}
          <h3 class="display text-xl font-extrabold text-body">{p.name}</h3>
          <p class="mt-1 text-sm text-dim">{p.tagline}</p>
          <div class="mt-5 display text-3xl font-extrabold text-body">Fərdi</div>
          <p class="text-xs text-dim">biznesinizə görə hesablanır</p>

          <ul class="mt-6 flex-1 space-y-3">
            {p.features.map((f) => (
              <li class="flex items-start gap-2.5 text-sm text-body">
                <svg class="mt-0.5 h-4 w-4 shrink-0 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                {f}
              </li>
            ))}
          </ul>

          <a href="/elaqe" class={`btn mt-7 ${p.featured ? 'btn-primary' : 'btn-ghost'}`}>Əlaqə saxla</a>
        </div>
      ))}
    </div>
  </div>
</section>
