---
import { useTranslations, localizedPath, type Lang } from '../i18n/ui'

const { lang } = Astro.props as { lang: Lang }
const t = useTranslations(lang)
---

<section class="cta-band" id="contact">
  <div class="aurora a1"></div>
  <div class="wrap cta-inner rv">
    <h2>{t('cta.title')}</h2>
    <p>{t('cta.sub')}</p>
    <div class="cta-buttons">
      <a href={localizedPath(lang, '/elaqe/')} class="btn btn-white">{t('cta.btn1')}</a>
    </div>
  </div>
</section>
