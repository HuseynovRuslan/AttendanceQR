---
import Button from './Button.astro'
import { SITE } from '../data/site'
---

<section class="bg-white py-16 sm:py-24">
  <div class="mx-auto max-w-6xl px-4 sm:px-6">
    <div class="overflow-hidden rounded-3xl bg-ink px-6 py-14 text-center sm:px-16">
      <h2 class="text-3xl font-bold text-white sm:text-4xl">İndi başlayın</h2>
      <p class="mx-auto mt-4 max-w-xl text-lg text-white/70">
        İşçi davamiyyətini QRLog ilə telefon üzərindən idarə edin — sadə, sürətli və etibarlı.
      </p>
      <div class="mt-8 flex justify-center">
        <Button href={SITE.appUrl} external variant="white">İşçi girişi</Button>
      </div>
    </div>
  </div>
</section>
