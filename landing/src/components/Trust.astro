---
import { useTranslations, type Lang } from '../i18n/ui'
import { TRUST_SECTORS, CUSTOMERS } from '../data/site'

const { lang } = Astro.props as { lang: Lang }
const t = useTranslations(lang)

// Named customers when we have them, the sector marquee when we do not — one or the other, never
// both. Three real names is a stronger and more honest claim than six sectors, which reads as a
// breadth of adoption we have not earned yet.
//
// The named version is a DARK band, deliberately: the page above it is white-to-paper with a blue
// aurora, so going to ink here stops the customers reading as one more pale row and gives them a
// stage. It borrows the hero's own dot grid and blue glow rather than introducing a second visual
// language for one section.
//
// Every logo sits on a WHITE tile. Both of the real ones were drawn for their own background —
// CleanFix blue-on-white, EastCaf a navy roundel — and EastCaf's navy is within a few shades of this
// band, so dropping it straight on would erase it. A white tile is also what keeps three logos of
// different shapes, crops and colour reading as one row instead of three pasted images.
//
// A company with no logo yet gets a monogram on the same tile, so the row stays even.
const icon =
  '<svg viewBox="0 0 24 24"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><path d="M14 14h3v3M20 20v.01M20 14v.01M14 20v.01"/></svg>'
const loop = [...TRUST_SECTORS, ...TRUST_SECTORS]
---

{CUSTOMERS.show ? (
  <section class="cust" aria-labelledby="cust-h">
    <div class="cust-bg" aria-hidden="true"></div>
    <div class="wrap cust-inner">
      <p class="cust-eyebrow rv">{t('cust.eyebrow')}</p>
      <h2 id="cust-h" class="cust-h rv">{t('cust.title')}</h2>

      <div class="cust-grid">
        {CUSTOMERS.items.map((c, i) => (
          <article class={`cust-card rv d${i + 1}`} style={`--accent:${c.accent}`}>
            <div class="cust-tile">
              {c.logo
                ? <img src={c.logo} alt={c.name} loading="lazy" decoding="async" />
                : <span class="cust-mono">{c.mark}</span>}
            </div>
            <h3>{c.name}</h3>
            <p>{t(`cust.${c.key}s` as any)}</p>
          </article>
        ))}
      </div>
    </div>
  </section>
) : (
  <div class="trust">
    <div class="wrap">
      <p>{t('trust.title')}</p>
    </div>
    <div class="marquee">
      <div class="marquee-track">
        {loop.map((o) => (
          <span class="mq-item"><Fragment set:html={icon} />{o}</span>
        ))}
      </div>
    </div>
  </div>
)}
