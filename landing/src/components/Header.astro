---
import { useTranslations, localizedPath, languages, type Lang } from '../i18n/ui'
import { SITE, PRICING } from '../data/site'

interface Props {
  lang: Lang
  /** Current route without the language prefix — the language switcher keeps you on this page. */
  path?: string
}
const { lang, path = '/' } = Astro.props
const t = useTranslations(lang)

// Section links are absolute (home + hash) so the same header works on /elaqe/ and /bloq/ too.
const home = localizedPath(lang, '/')
const links = [
  { href: `${home}#how`, label: t('nav.how') },
  { href: `${home}#features`, label: t('nav.features') },
  ...(PRICING.enabled ? [{ href: localizedPath(lang, '/qiymet/'), label: t('nav.pricing') }] : []),
  { href: `${home}#faq`, label: t('nav.faq') },
  { href: localizedPath(lang, '/elaqe/'), label: t('nav.contact') },
]
---

<header>
  <div class="wrap nav">
    <a class="brand" href={home} aria-label={SITE.name}>
      <img src="/logo-word.png" alt={SITE.name} width="150" height="30" />
    </a>
    <nav class="nav-links" id="navlinks" aria-label="Main">
      {links.map((l) => <a href={l.href}>{l.label}</a>)}
    </nav>
    <div class="nav-right">
      <div class="lang" role="group" aria-label={t('a11y.lang')}>
        {languages.map((l) => (
          <a
            href={localizedPath(l, path)}
            class={l === lang ? 'active' : ''}
            hreflang={l}
            aria-current={l === lang ? 'true' : undefined}
          >{l.toUpperCase()}</a>
        ))}
      </div>
      <!--
        No staff-login link anywhere on this site: the marketing pages point at sales, and people
        who already use QRLog reach the app by its own address. Under 560px this button is hidden
        by global.css, which is fine — "Əlaqə" is in the mobile menu above.
      -->
      <a class="btn btn-primary" href={localizedPath(lang, '/elaqe/')}>{t('cta.btn1')}</a>
      <button class="menu-toggle" id="menuToggle" aria-label={t('nav.menu')} aria-expanded="false">
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>
</header>
