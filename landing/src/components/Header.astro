---
import { SITE } from '../data/site'

const nav = [
  { label: 'Xüsusiyyətlər', href: '/#xususiyyetler' },
  { label: 'Necə işləyir', href: '/#nece-isleyir' },
  { label: 'Qiymət', href: '/#qiymet' },
  { label: 'Əlaqə', href: '/elaqe' },
]
---

<header class="header-bg sticky top-0 z-50 border-b border-hair backdrop-blur-md">
  <div class="mx-auto flex h-16 max-w-6xl items-center justify-between gap-4 px-4 sm:px-6">
    <!-- Brand: inline so it adapts to light/dark rather than a baked PNG. -->
    <a href="/" class="flex items-center gap-2.5" aria-label="QRLog ana səhifə">
      <svg class="h-8 w-8 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><path d="M14 14h3v3M21 14v3M14 21h7M21 17v4"/>
      </svg>
      <span class="display text-xl font-extrabold text-body">QRLog</span>
    </a>

    <nav class="hidden items-center gap-7 md:flex" aria-label="Əsas naviqasiya">
      {nav.map((i) => (
        <a href={i.href} class="text-sm font-semibold text-dim transition hover:text-accent">{i.label}</a>
      ))}
    </nav>

    <div class="flex items-center gap-2 sm:gap-3">
      <button id="theme-toggle" type="button" aria-label="İşıq/qaranlıq rejim"
        class="grid h-9 w-9 place-items-center rounded-lg border border-hair text-dim transition hover:text-accent">
        <svg class="icon-sun h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4"/></svg>
        <svg class="icon-moon h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z"/></svg>
      </button>

      <a href={SITE.appUrl} target="_blank" rel="noopener noreferrer"
        class="hidden text-sm font-semibold text-dim transition hover:text-accent lg:inline-flex">İşçi girişi</a>
      <a href="/elaqe" class="btn btn-primary !px-4 !py-2 !text-sm">Demo istə</a>

      <button id="menu-toggle" type="button" aria-label="Menyu" aria-expanded="false"
        class="grid h-9 w-9 place-items-center rounded-lg border border-hair text-dim md:hidden">
        <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M4 7h16M4 12h16M4 17h16"/></svg>
      </button>
    </div>
  </div>

  <div id="mobile-menu" class="hidden border-t border-hair bg-base md:hidden">
    <nav class="mx-auto flex max-w-6xl flex-col gap-1 px-4 py-3" aria-label="Mobil naviqasiya">
      {nav.map((i) => (
        <a href={i.href} class="rounded-lg px-3 py-2.5 text-sm font-semibold text-body transition hover:bg-surface">{i.label}</a>
      ))}
      <a href={SITE.appUrl} target="_blank" rel="noopener noreferrer" class="rounded-lg px-3 py-2.5 text-sm font-semibold text-dim">İşçi girişi</a>
    </nav>
  </div>
</header>

<script is:inline>
  (() => {
    const root = document.documentElement
    const saved = localStorage.getItem('qrlog-theme')
    if (saved) root.setAttribute('data-theme', saved)

    document.getElementById('theme-toggle')?.addEventListener('click', () => {
      const current =
        root.getAttribute('data-theme') ||
        (matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light')
      const next = current === 'dark' ? 'light' : 'dark'
      root.setAttribute('data-theme', next)
      localStorage.setItem('qrlog-theme', next)
    })

    const menu = document.getElementById('mobile-menu')
    const btn = document.getElementById('menu-toggle')
    btn?.addEventListener('click', () => {
      const hidden = menu?.classList.toggle('hidden')
      btn.setAttribute('aria-expanded', String(hidden === false))
    })
    menu?.querySelectorAll('a').forEach((a) => a.addEventListener('click', () => menu.classList.add('hidden')))
  })()
</script>
