---
// Hero signature moment: a phone scans a QR, a scan line sweeps, GPS confirms inside the geofence,
// and — on the live panel floating beside it — one employee flips from "Qayıb" to "İşdə" the instant
// the scan lands. Pure CSS + a tiny cycler. No face/photo step (biometric review pending); the
// anti-fraud story here is GPS + device only. Freezes to a calm static state under reduced-motion.
---

<div class="hero-anim relative mx-auto w-full max-w-[440px]" aria-hidden="true">
  <!-- ambient glow behind the scene -->
  <span class="glow-blob" style="width:340px;height:340px;top:-40px;right:-30px;opacity:.7"></span>

  <!-- floating live panel (behind, offset up-right) -->
  <div class="panel-float panel-card absolute -right-2 -top-6 z-20 w-[220px] p-3 backdrop-blur-xl sm:-right-6"
       style="background:var(--panel);border-color:var(--panel-border)">
    <div class="flex items-center justify-between px-1">
      <span class="text-[11px] font-bold on-panel">Canlı panel</span>
      <span class="flex items-center gap-1 text-[10px] font-semibold" style="color:var(--good)">
        <span class="dot live-dot" style="background:var(--good)"></span> Bugün
      </span>
    </div>
    <!-- rows -->
    <div class="mt-2 space-y-1.5">
      <div class="prow flex items-center justify-between rounded-lg px-2 py-1.5" style="background:var(--panel-surface)">
        <div class="flex items-center gap-2">
          <span class="grid h-6 w-6 place-items-center rounded-full text-[10px] font-bold" style="background:rgba(88,162,236,.2);color:#7cbaf3">AH</span>
          <span class="text-[11px] font-semibold on-panel">Aygün H.</span>
        </div>
        <span class="chip chip-good text-[9px]"><span class="dot" style="background:var(--good)"></span>İşdə</span>
      </div>
      <!-- THIS row flips qayıb → işdə -->
      <div class="prow prow-flip flex items-center justify-between rounded-lg px-2 py-1.5" style="background:var(--panel-surface)">
        <div class="flex items-center gap-2">
          <span class="grid h-6 w-6 place-items-center rounded-full text-[10px] font-bold" style="background:rgba(88,162,236,.2);color:#7cbaf3">RM</span>
          <span class="text-[11px] font-semibold on-panel">Rəşad M.</span>
        </div>
        <span class="flip-wrap relative inline-grid text-[9px]">
          <span class="flip-absent chip text-[9px]" style="background:rgba(255,255,255,.06);color:var(--on-panel-dim)"><span class="dot" style="background:var(--on-panel-dim)"></span>Qayıb</span>
          <span class="flip-present chip chip-good text-[9px]"><span class="dot" style="background:var(--good)"></span>İşdə</span>
        </span>
      </div>
      <div class="prow flex items-center justify-between rounded-lg px-2 py-1.5" style="background:var(--panel-surface)">
        <div class="flex items-center gap-2">
          <span class="grid h-6 w-6 place-items-center rounded-full text-[10px] font-bold" style="background:rgba(88,162,236,.2);color:#7cbaf3">NƏ</span>
          <span class="text-[11px] font-semibold on-panel">Nihad Ə.</span>
        </div>
        <span class="chip chip-good text-[9px]"><span class="dot" style="background:var(--good)"></span>İşdə</span>
      </div>
    </div>
    <div class="mt-2 flex items-center justify-between border-t px-1 pt-2 text-[10px]" style="border-color:var(--panel-border)">
      <span class="on-panel-dim">Davamiyyət</span>
      <span class="num font-bold on-panel"><span class="counter" data-to="42">41</span>/55 işdə</span>
    </div>
  </div>

  <!-- phone (front) -->
  <div class="phone relative z-10 mx-auto w-[268px]">
    <div class="rounded-[2.6rem] p-2.5" style="background:var(--panel-2);box-shadow:var(--shadow-lg)">
      <div class="relative h-[420px] overflow-hidden rounded-[2.1rem]" style="background:var(--panel)">
        <!-- app bar -->
        <div class="flex items-center justify-between px-5 pt-5">
          <span class="text-sm font-bold on-panel">QRLog</span>
          <span class="flex items-center gap-1.5 text-[11px] font-semibold" style="color:var(--accent-2)">
            <span class="live-dot dot" style="background:var(--accent-2)"></span> Skan
          </span>
        </div>

        <!-- QR target -->
        <div class="mt-8 flex flex-col items-center">
          <div class="relative grid h-44 w-44 place-items-center rounded-[1.4rem]" style="background:rgba(255,255,255,.04);border:1px solid var(--panel-border)">
            <span class="corner" style="top:12px;left:12px;border-width:2px 0 0 2px"></span>
            <span class="corner" style="top:12px;right:12px;border-width:2px 2px 0 0"></span>
            <span class="corner" style="bottom:12px;left:12px;border-width:0 0 2px 2px"></span>
            <span class="corner" style="bottom:12px;right:12px;border-width:0 2px 2px 0"></span>
            <svg viewBox="0 0 24 24" class="h-24 w-24" style="color:var(--on-panel)" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="3" width="7" height="7" rx="1.5"/><rect x="14" y="3" width="7" height="7" rx="1.5"/><rect x="3" y="14" width="7" height="7" rx="1.5"/><path d="M14 14h3v3M21 14v3M14 21h7M21 17v4"/>
            </svg>
            <span class="scanline"></span>
          </div>
          <p class="mt-5 text-sm font-semibold on-panel">QR kodu skan edin</p>
          <p class="mt-1 text-xs on-panel-dim">İş yerindəki kodu telefonla oxudun</p>
        </div>

        <!-- GPS confirm toast (rises on cue) -->
        <div class="gps-toast panel-card absolute bottom-5 left-4 right-4 flex items-center gap-2.5 px-3 py-2.5"
             style="background:var(--panel-2)">
          <span class="relative grid h-8 w-8 shrink-0 place-items-center rounded-lg" style="background:var(--good-soft);color:var(--good)">
            <span class="ping" style="border-color:var(--good)"></span>
            <svg viewBox="0 0 24 24" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0z"/><circle cx="12" cy="10" r="3"/></svg>
          </span>
          <div class="min-w-0">
            <p class="text-xs font-bold on-panel">Məkan təsdiqləndi</p>
            <p class="text-[11px] on-panel-dim">İş ərazisinin içindəsiniz</p>
          </div>
          <svg viewBox="0 0 24 24" class="check ml-auto h-5 w-5 shrink-0" style="color:var(--good)" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .panel-float { animation: floatUp .9s var(--ease) .2s both, bob 6s ease-in-out 1.2s infinite; }
  .phone { animation: floatUp .9s var(--ease) both; }
  @keyframes floatUp { from { opacity: 0; transform: translateY(24px); } to { opacity: 1; transform: none; } }
  @keyframes bob { 0%,100% { transform: translateY(0); } 50% { transform: translateY(-7px); } }

  .corner { position: absolute; width: 20px; height: 20px; border-style: solid; border-color: var(--accent-2); border-radius: 3px; }

  .scanline {
    position: absolute; left: 14%; right: 14%; height: 2px; border-radius: 2px;
    background: linear-gradient(90deg, transparent, var(--accent-2), transparent);
    box-shadow: 0 0 14px 3px var(--glow);
    animation: sweep 2.6s var(--ease) infinite;
  }
  @keyframes sweep { 0%,100% { top: 20%; opacity: .25; } 50% { top: 76%; opacity: 1; } }

  .gps-toast { opacity: 0; transform: translateY(14px); animation: toast 5.2s ease-in-out infinite; }
  @keyframes toast {
    0%, 34% { opacity: 0; transform: translateY(14px); }
    46%, 88% { opacity: 1; transform: translateY(0); }
    100% { opacity: 0; transform: translateY(14px); }
  }
  .check path { stroke-dasharray: 30; stroke-dashoffset: 30; animation: draw 5.2s ease-in-out infinite; }
  @keyframes draw { 0%,44% { stroke-dashoffset: 30; } 56%,100% { stroke-dashoffset: 0; } }

  .ping { position: absolute; inset: 0; border-radius: inherit; border: 2px solid; opacity: 0; animation: ping 1.8s cubic-bezier(0,0,.2,1) infinite; }
  @keyframes ping { 0% { transform: scale(1); opacity: .6; } 80%,100% { transform: scale(1.5); opacity: 0; } }

  .live-dot { animation: blink 1.5s ease-in-out infinite; }
  @keyframes blink { 0%,100% { opacity: 1; } 50% { opacity: .3; } }

  .flip-wrap > * { grid-area: 1 / 1; transition: opacity .4s var(--ease), transform .4s var(--ease); }
  .flip-absent { animation: flipOut 5.2s ease-in-out infinite; }
  .flip-present { animation: flipIn 5.2s ease-in-out infinite; }
  @keyframes flipOut { 0%,46% { opacity: 1; transform: translateY(0); } 54%,100% { opacity: 0; transform: translateY(-6px); } }
  @keyframes flipIn  { 0%,46% { opacity: 0; transform: translateY(6px); } 54%,100% { opacity: 1; transform: translateY(0); } }
  .prow-flip { animation: rowGlow 5.2s ease-in-out infinite; }
  @keyframes rowGlow {
    0%,46% { box-shadow: 0 0 0 0 transparent; }
    54% { box-shadow: 0 0 0 1px var(--good); }
    70%,100% { box-shadow: 0 0 0 0 transparent; }
  }
  .counter { display: inline-block; }

  @media (prefers-reduced-motion: reduce) {
    .panel-float, .phone { animation: none; opacity: 1; }
    .scanline, .gps-toast, .ping, .live-dot, .flip-absent, .prow-flip { animation: none; }
    .gps-toast { opacity: 1; transform: none; }
    .flip-absent { opacity: 0; } .flip-present { opacity: 1; }
    .check path { stroke-dashoffset: 0; animation: none; }
  }
</style>

<script>
  const root = document.querySelector('.hero-anim')
  const counter = root?.querySelector('.counter') as HTMLElement | null
  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches
  if (counter && !reduce) {
    setInterval(() => {
      counter.textContent = '42'
      setTimeout(() => { counter.textContent = '41' }, 4000)
    }, 5200)
    setTimeout(() => { counter.textContent = '42' }, 2860)
  }
</script>
