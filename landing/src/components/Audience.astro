---
import Icon from './Icon.astro'
import { AUDIENCE } from '../data/site'
---

<section class="bg-base py-18 sm:py-24">
  <div class="mx-auto max-w-6xl px-4 sm:px-6">
    <div class="mx-auto max-w-2xl text-center">
      <span class="eyebrow centered">Kimlər üçün</span>
      <h2 class="display mt-4 text-3xl font-extrabold text-body sm:text-4xl">İşçiləri müxtəlif yerlərdə olan biznes üçün</h2>
      <p class="mt-4 text-lg text-dim">Xüsusən bir neçə obyekt, filial və ya növbəli heyəti idarə edənlər üçün.</p>
    </div>

    <div class="mt-12 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {AUDIENCE.map((a) => (
        <div class="card card-hover flex items-start gap-4 p-5">
          <span class="tile-icon shrink-0"><Icon name={a.icon} class="h-6 w-6" /></span>
          <div>
            <h3 class="text-base font-bold text-body">{a.title}</h3>
            <p class="mt-1 text-sm text-dim">{a.text}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
