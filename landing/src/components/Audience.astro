---
import Icon from './Icon.astro'
import { AUDIENCE } from '../data/site'
---

<section class="bg-white py-16 sm:py-24">
  <div class="mx-auto max-w-6xl px-4 sm:px-6">
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="text-3xl font-bold text-ink sm:text-4xl">Kimlər üçün?</h2>
      <p class="mt-4 text-lg text-muted">
        İşçi davamiyyətini izləmək istəyən istənilən təşkilat üçün uyğundur.
      </p>
    </div>

    <div class="mt-14 grid gap-6 sm:grid-cols-2 lg:grid-cols-5">
      {AUDIENCE.map((a) => (
        <div class="rounded-2xl border border-ink/10 p-6 text-center transition hover:border-primary/40 hover:shadow-sm">
          <div class="mx-auto grid h-12 w-12 place-items-center rounded-xl bg-primary/10 text-primary">
            <Icon name={a.icon} class="h-6 w-6" />
          </div>
          <h3 class="mt-4 text-base font-bold text-ink">{a.title}</h3>
          <p class="mt-1 text-sm text-muted">{a.text}</p>
        </div>
      ))}
    </div>
  </div>
</section>
