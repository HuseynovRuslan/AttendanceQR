---
import { useTranslations, type Lang } from '../i18n/ui'

const { lang } = Astro.props as { lang: Lang }
const t = useTranslations(lang)

// Four claims we can actually point at in the running system: TLS everywhere, fail-closed tenant
// isolation, nightly backups with tested restores, and role-based scope. No GDPR badge and no
// "end-to-end encryption" — neither is true of this stack.
const items = [
  { t: 'sec.i1t', d: 'sec.i1d', p: '<rect x="4" y="10" width="16" height="10" rx="2"/><path d="M8 10V7a4 4 0 0 1 8 0v3"/><circle cx="12" cy="15" r="1.4"/>' },
  { t: 'sec.i2t', d: 'sec.i2d', p: '<path d="M12 3 4 6v5c0 5 3.4 8.5 8 10 4.6-1.5 8-5 8-10V6l-8-3Z"/><path d="m9 12 2 2 4-4"/>' },
  { t: 'sec.i3t', d: 'sec.i3d', p: '<ellipse cx="12" cy="6" rx="8" ry="3"/><path d="M4 6v12c0 1.7 3.6 3 8 3s8-1.3 8-3V6"/><path d="M4 12c0 1.7 3.6 3 8 3s8-1.3 8-3"/>' },
  { t: 'sec.i4t', d: 'sec.i4d', p: '<circle cx="9" cy="8" r="3"/><path d="M3 20v-1a5 5 0 0 1 5-5h2"/><path d="M15 11l2 2 4-4"/>' },
]
---

<section class="sec" id="security">
  <div class="wrap">
    <div class="sec-head rv">
      <span class="eyebrow">{t('sec.eyebrow')}</span>
      <h2>{t('sec.title')}</h2>
      <p>{t('sec.sub')}</p>
    </div>
    <div class="sec-grid">
      {items.map((s, i) => (
        <div class={`sec-item rv d${i + 1}`}>
          <div class="ic"><svg viewBox="0 0 24 24" set:html={s.p} /></div>
          <h3>{t(s.t as any)}</h3>
          <p>{t(s.d as any)}</p>
        </div>
      ))}
    </div>
  </div>
</section>
