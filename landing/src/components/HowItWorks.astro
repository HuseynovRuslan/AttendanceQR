---
import { useTranslations, type Lang } from '../i18n/ui';
const { lang } = Astro.props as { lang: Lang };
const t = useTranslations(lang);
---
<section class="how" id="how">
  <div class="wrap">
    <div class="sec-head rv">
      <span class="eyebrow">{t('how.eyebrow')}</span>
      <h2>{t('how.title')}</h2>
      <p>{t('how.sub')}</p>
    </div>
    <div class="steps">
      <div class="step rv d1"><div class="n">01</div><h3>{t('how.s1t')}</h3><p>{t('how.s1d')}</p></div>
      <div class="step rv d2"><div class="n">02</div><h3>{t('how.s2t')}</h3><p>{t('how.s2d')}</p></div>
      <div class="step rv d3"><div class="n">03</div><h3>{t('how.s3t')}</h3><p>{t('how.s3d')}</p></div>
    </div>
  </div>
</section>
