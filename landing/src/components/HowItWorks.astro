---
import { STEPS } from '../data/site'
---

<section id="nece-isleyir" class="bg-soft py-16 sm:py-24">
  <div class="mx-auto max-w-6xl px-4 sm:px-6">
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="text-3xl font-bold text-ink sm:text-4xl">Necə işləyir?</h2>
      <p class="mt-4 text-lg text-muted">Üç sadə addım — quraşdırma dəqiqələr çəkir.</p>
    </div>

    <ol class="mt-14 grid gap-8 md:grid-cols-3">
      {STEPS.map((s) => (
        <li class="relative rounded-2xl bg-white p-8 text-center shadow-sm ring-1 ring-ink/5">
          <span class="mx-auto grid h-12 w-12 place-items-center rounded-full bg-primary text-lg font-bold text-white">
            {s.n}
          </span>
          <h3 class="mt-5 text-lg font-bold text-ink">{s.title}</h3>
          <p class="mt-2 text-sm leading-relaxed text-muted">{s.text}</p>
        </li>
      ))}
    </ol>
  </div>
</section>
