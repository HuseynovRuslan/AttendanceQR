---
import BaseLayout from '../../layouts/BaseLayout.astro'
import PageHero from '../../components/PageHero.astro'
import { useTranslations } from '../../i18n/ui'
import { getCollection } from 'astro:content'

// The blog is Azerbaijani only — there is no /ru/bloq/ or /en/bloq/, and the footer in every
// language points here. Translating posts is a content decision, not a routing one.
const lang = 'az' as const
const t = useTranslations(lang)

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
)

const fmt = (d: Date) =>
  d.toLocaleDateString('az-AZ', { year: 'numeric', month: 'long', day: 'numeric' })
---

<BaseLayout lang={lang} path="/bloq/" title={t('blog.metaTitle')} description={t('blog.metaDesc')}>
  <PageHero title={t('blog.title')} subtitle={t('blog.sub')} />
  <section class="prose-section">
    <div class="wrap post-list">
      {posts.length === 0 ? (
        <p class="empty">{t('blog.empty')}</p>
      ) : (
        posts.map((post) => (
          <a class="post-card" href={`/bloq/${post.id}/`}>
            <time datetime={post.data.pubDate.toISOString()}>{fmt(post.data.pubDate)}</time>
            <h2>{post.data.title}</h2>
            <p>{post.data.description}</p>
          </a>
        ))
      )}
    </div>
  </section>
</BaseLayout>
