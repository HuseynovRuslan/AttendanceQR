---
import BaseLayout from '../layouts/BaseLayout.astro'
import PageHero from '../components/PageHero.astro'
---

<BaseLayout
  title="Haqqımızda — QRLog"
  description="QRLog — Azərbaycanda QR əsaslı işçi davamiyyəti sistemi. Missiyamız davamiyyət uçotunu sadələşdirməkdir."
>
  <PageHero title="Haqqımızda" subtitle="QR əsaslı davamiyyət sistemi." />
  <section class="bg-white py-16">
    <div class="mx-auto max-w-2xl px-4 sm:px-6">
      <p class="text-lg leading-relaxed text-muted">
        QRLog işçi davamiyyətinin uçotunu sadə, sürətli və etibarlı etmək üçün yaradılıb. Turniket və
        ya bahalı terminallar əvəzinə işçilər öz telefonları ilə QR kodu skan edir — GPS, foto təsdiqi
        və cihaz bağlaması saxtakarlığın qarşısını alır.
      </p>
      <p class="mt-4 text-lg leading-relaxed text-muted">
        Bu səhifə tezliklə komanda və missiyamız haqqında ətraflı məlumatla tamamlanacaq.
      </p>
    </div>
  </section>
</BaseLayout>
