---
import BaseLayout from '../../layouts/BaseLayout.astro'
import PageHero from '../../components/PageHero.astro'
import ContactBody from '../../components/ContactBody.astro'
import { useTranslations } from '../../i18n/ui'
const lang = 'ru' as const
const t = useTranslations(lang)
---
<BaseLayout lang={lang} path="/elaqe/" title={t('contact.metaTitle')} description={t('contact.metaDesc')}>
  <PageHero title={t('contact.title')} subtitle={t('contact.sub')} />
  <ContactBody lang={lang} />
</BaseLayout>
