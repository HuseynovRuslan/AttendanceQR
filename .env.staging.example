# Staging environment. Copy to .env.staging on the server and fill in fresh values.
#
# The secrets here MUST NOT match production's. A staging token that opens production is not a
# staging environment — it is production with a second front door, and staging is by design the
# place where things are broken and left broken.

POSTGRES_USER=qrlog_stg
POSTGRES_PASSWORD=            # openssl rand -hex 24
POSTGRES_DB=qrlog_stg

Jwt__SigningKey=              # openssl rand -base64 48
QrToken__Secret=              # openssl rand -base64 48

VITE_API_URL=https://api-test.qrlog.az
Cors__AllowedOrigins=https://test.qrlog.az

# The single tenant staging serves, so test.qrlog.az resolves to a company on first boot.
# Idempotent by slug: it runs once and does nothing on later starts.
TenantSeed__Slug=test
TenantSeed__Name=Test şirkəti
TenantSeed__AdminPhone=+994500000000
TenantSeed__AdminPin=1234

# No super-admins in staging: the group console reads across tenants and there is only one here.
App__SuperAdminEmployeeIds=
