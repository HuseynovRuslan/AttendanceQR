# Automatic HTTPS for the production stack. Caddy fetches and renews Let's Encrypt certificates on
# its own, the moment these names resolve to this server. The app lives under bax.qrlog.az; the apex
# qrlog.az is a separate landing page and is intentionally not handled here.

bax.qrlog.az {
	encode zstd gzip
	reverse_proxy frontend:80
}

api.qrlog.az {
	encode zstd gzip
	reverse_proxy backend:8080
}
