# Automatic HTTPS for the production stack. Caddy fetches and renews Let's Encrypt certificates on
# its own, the moment these names resolve to this server.
#   bax.qrlog.az  → the attendance app (frontend)
#   api.qrlog.az  → the backend API
#   qrlog.az      → the static marketing site (Astro build, served from /srv/qrlog, which is the
#                   host's ./landing-dist — produced by ops/build-landing.sh, not by compose)
#   <slug>.qrlog.az → any tenant, certificate issued on demand (see the catch-all at the bottom)

{
	# On-demand TLS: a certificate is fetched the first time a hostname is requested, but only if
	# the backend says that hostname belongs to a real, active tenant. Without the ask, anyone
	# pointing a DNS name here could make us request certificates on their behalf until Let's
	# Encrypt rate-limits the whole domain. Caddy appends ?domain=<host> to this URL itself.
	on_demand_tls {
		ask http://backend:8080/api/tenant/allow-tls
	}
}

# www → apex. The site declares https://qrlog.az/… as canonical in every <link rel="canonical">, so
# serving the same pages under both names would have search engines picking between two copies.
www.qrlog.az {
	redir https://qrlog.az{uri} permanent
}

qrlog.az {
	encode zstd gzip
	root * /srv/qrlog

	# Astro fingerprints everything it emits under /_astro/, so those files can be cached forever.
	# HTML deliberately is not: a deploy has to reach people who already have the page open.
	@immutable path /_astro/*
	header @immutable Cache-Control "public, max-age=31536000, immutable"

	# Pages, the sitemap and robots.txt must revalidate, or a deploy would leave stale HTML in
	# browsers. `*/` covers the directory URLs the site actually serves (/qiymet/, /ru/elaqe/, …).
	@revalidate path */ *.html *.xml /robots.txt
	header @revalidate Cache-Control "no-cache"

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		X-Frame-Options "SAMEORIGIN"
		-Server
	}

	file_server

	# The site is a multi-page build now (/, /qiymet/, /haqqimizda/, /elaqe/, /bloq/… in three
	# languages), so a mistyped path is a real possibility. Serve the built 404 page and keep the
	# 404 status — a "not found" that answers 200 gets indexed as a real page.
	handle_errors 404 {
		rewrite * /404.html
		file_server {
			status 404
		}
	}
}

bax.qrlog.az {
	encode zstd gzip
	reverse_proxy frontend:80
}

# EastCaf (tenant "ecaf") and CleanFix — kept as explicit blocks even though the catch-all below
# would now cover them. They have working certificates and there is no reason to move a live tenant
# onto a new code path to prove a point; new tenants need no block at all.
ecaf.qrlog.az {
	encode zstd gzip
	reverse_proxy frontend:80
}

cleanfix.qrlog.az {
	encode zstd gzip
	reverse_proxy frontend:80
}

api.qrlog.az {
	encode zstd gzip
	reverse_proxy backend:8080
}

# Staging (docker-compose.staging.yml). Its containers join the same Docker network under the
# aliases stg-frontend / stg-backend; nothing else is shared with production, not even the database.
#
# These two blocks used to exist only as a hand edit of this file ON THE SERVER, and nothing in the
# repository knew about them. Recreating the Caddy container for an unrelated change was therefore
# enough to take staging off the internet — which is exactly what happened on 2026-07-24, silently,
# because a working staging deploy still reports success while nobody can reach it.
#
# Both names must stay above the catch-all's reach: without a block they would be matched by the
# on-demand `https://` site at the bottom and proxied to PRODUCTION, which is worse than a 404.
test.qrlog.az {
	encode zstd gzip
	reverse_proxy stg-frontend:80
}

api-test.qrlog.az {
	encode zstd gzip
	reverse_proxy stg-backend:8080
}

# Every tenant from here on, without a block of its own. Adding a company used to mean editing this
# file and restarting Caddy over SSH — which is why the super-admin panel could not finish the job.
#
# This is a CATCH-ALL, not a wildcard. `*.qrlog.az` as a site address is what broke this before: it
# makes Caddy manage a *wildcard certificate*, which needs DNS-01, and failing that it took the
# explicit hosts down with it. `https://` names no host at all — it simply matches whatever the more
# specific blocks above did not, and each hostname then gets its own ordinary single-host
# certificate, issued on first request and gated by the ask above.
#
# Order does not decide this — Caddy routes by specificity, so bax/api/qrlog.az still win over it.
https:// {
	encode zstd gzip
	tls {
		on_demand
	}
	reverse_proxy frontend:80
}
