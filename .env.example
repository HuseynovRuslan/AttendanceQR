# ─────────────────────────────────────────────────────────────────────────────
# AttendanceQR — environment variables for local `docker compose up`.
# Copy this file to `.env` (which is gitignored) and fill in real values.
# In production (Coolify) these are set as the application's secrets/env — NOT here.
#
# NOTE: the double underscore "__" is ASP.NET Core's nested-key separator, so
#       Jwt__SigningKey  ==  configuration key  Jwt:SigningKey.
# ─────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL (the compose `db` service) ────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-to-a-strong-password
POSTGRES_DB=attendanceqr

# ── Backend secrets (REQUIRED — compose refuses to start if unset) ────────────
# JWT login-token signing key.   Generate:  openssl rand -base64 64
Jwt__SigningKey=
# QR HMAC signing secret.         Generate:  openssl rand -base64 48
QrToken__Secret=

# Comma-separated list of origins allowed to call the API (the frontend URL).
# Local compose serves the SPA on :8081.
Cors__AllowedOrigins=http://localhost:8081

# ── First-admin bootstrap ────────────────────────────────────────────────────
# On first startup, if these are set AND no Admin exists yet, the backend creates
# one Admin account (plus a starter location) so you can log in. Idempotent — once
# an Admin exists it is skipped, so it is safe to leave these set.
# AdminPassword is the login PIN — must be EXACTLY 4 digits (same format employees set at
# activation); if it isn't, bootstrap is skipped and logged as an error.
Bootstrap__AdminEmail=admin@example.com
Bootstrap__AdminPassword=1234
Bootstrap__AdminFullName=Administrator

# ── Emergency admin PIN reset (leave both empty/unset normally) ───────────────
# There is no self-service "forgot PIN" flow. If an admin is locked out, set both
# of these, redeploy, confirm the "Ops:ResetAdminPassword applied" line in the
# startup log, then log in and REMOVE both vars — unlike Bootstrap above, this is
# NOT idempotent-by-admin-existing: it reapplies on every startup while set.
Ops__ResetAdminEmail=
Ops__ResetAdminPassword=

# ── Frontend build ───────────────────────────────────────────────────────────
# Public URL of the backend API — baked into the SPA at build time.
VITE_API_URL=http://localhost:8080

# ── Production (Coolify) note ────────────────────────────────────────────────
# The backend also needs the DB connection string. Locally compose builds it from
# POSTGRES_* above; in production set it directly on the backend app, e.g.:
#   ConnectionStrings__DefaultConnection=Host=<db-host>;Port=5432;Database=attendanceqr;Username=<user>;Password=<pass>
