{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": ""
  },
  "QrToken": {
    "Secret": "",
    "TtlSeconds": 60
  },
  "Jwt": {
    "Issuer": "AttendanceQR",
    "Audience": "AttendanceQR",
    "SigningKey": "",
    "ExpiryMinutes": 52560000
  },
  "Invitation": {
    "ExpiryHours": 72
  },
  "Cors": {
    "AllowedOrigins": ""
  },
  "App": {
    "TimeZone": "Asia/Baku",
    // Employee ids allowed to manage tenants. Empty here on purpose — set it per environment
    // (App__SuperAdminEmployeeIds), never in a file that ships. Empty = the screen does not exist.
    "SuperAdminEmployeeIds": ""
  },
  "DeviceBinding": {
    "AutoBind": true,
    "MaxActiveDevices": 3,
    "MaxBindsPer30Days": 3
  },
  "Storage": {
    "Minio": {
      "Endpoint": "",
      "AccessKey": "",
      "SecretKey": "",
      "BucketName": "attendance-photos",
      "UseSsl": true,
      "Region": "",
      "PublicUrlExpirySeconds": 300,
      "RetentionDays": 90
    }
  },
  "Rekognition": {
    "AccessKey": "",
    "SecretKey": "",
    "Region": "us-east-1",
    "SimilarityThreshold": 85
  }
}
